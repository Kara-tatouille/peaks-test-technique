{% extends 'base.html.twig' %}

{% block title %}Regions{% endblock %}

{% block body %}
    <h1>Régions</h1>
    <ul>
        {% for region in regions %}
            <li><a href="{{ path('app_department', {code: region.code}) }}">{{ region.code }} - {{ region.name }}</a></li>
        {% endfor %}
    </ul>
{% endblock %}
